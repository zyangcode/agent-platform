        <mxCell id="legend" value="图例：实线 = 平台核心库内关系 / 外键候选；红色虚线 = 跨服务引用，不做数据库外键；tenant_id、created_at 等通用字段未全部画出。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F9FAFB;strokeColor=#9CA3AF;fontColor=#374151;fontSize=13;spacing=10;" vertex="1" parent="1">
