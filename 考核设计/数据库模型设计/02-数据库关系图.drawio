        <mxCell id="title" value="AI Agent 平台数据库关系图（按正式数据库模型设计）" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=24;fontStyle=1;fontColor=#1F2937;" vertex="1" parent="1">
