<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="Agent Loop Detail Flow">
    <mxGraphModel dx="1500" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="Agent 循环细化流程：runModelLoop(...)&#xa;重点：14 的直接工具判断不调用模型；真正“模型决定工具”发生在 parseToolCall(...)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#111827;fontColor=#ffffff;fontStyle=1;fontSize=22;align=center;verticalAlign=middle;spacing=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="30" width="1340" height="86" as="geometry" />
        </mxCell>

        <mxCell id="legend" value="图例&#xa;蓝色矩形：普通处理步骤&#xa;黄色菱形：判断分支&#xa;橙色：工具执行/工具结果&#xa;紫色：模型调用&#xa;绿色：循环结束/返回结果&#xa;灰色虚线：说明，不是运行步骤" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#94a3b8;fontColor=#334155;fontSize=13;align=left;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="145" width="330" height="145" as="geometry" />
        </mxCell>

        <mxCell id="noteDirect" value="14 为什么不用模型？&#xa;detectDirectToolCall(...) 是规则预判：&#xa;1. Skill 必须已授权可用&#xa;2. calculator：正则识别算式 + 文本像“计算/等于/what is”&#xa;3. weather：文本包含“天气/weather”，并能提取城市&#xa;4. search：文本包含“搜索/查询/search”&#xa;命中才直接生成 ToolCall；否则返回 null，交给模型处理。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#f97316;fontColor=#9a3412;fontSize=13;align=left;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="145" width="460" height="145" as="geometry" />
        </mxCell>

        <mxCell id="noteModelTool" value="模型决定工具在哪里？&#xa;模型调用后，如果 assistantMessage 以：&#xa;@skill:toolName {json参数}&#xa;或 @mcp:toolName {json参数}&#xa;开头，parseToolCall(...) 会解析出 ToolCall，随后执行工具，并把工具结果写回 messages，再进入下一轮模型调用。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#8b5cf6;fontColor=#5b21b6;fontSize=13;align=left;verticalAlign=middle;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="930" y="145" width="490" height="145" as="geometry" />
        </mxCell>

        <mxCell id="start" value="开始&#xa;DefaultAgentRuntimeService.run(...)&#xa;已拿到 AgentContextDTO" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#166534;fontSize=13;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="620" y="335" width="260" height="82" as="geometry" />
        </mxCell>

        <mxCell id="copyMessages" value="1. 复制上下文 messages&#xa;List&lt;ModelMessage&gt; messages = new ArrayList&lt;&gt;(context.messages())&#xa;后续工具结果会追加到这个列表里" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1e3a8a;fontSize=13;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="560" y="465" width="380" height="95" as="geometry" />
        </mxCell>

        <mxCell id="directDecision" value="2. 规则能直接判断工具吗？&#xa;detectDirectToolCall(userInput, context)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#92400e;fontSize=12;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="600" y="625" width="300" height="150" as="geometry" />
        </mxCell>

        <mxCell id="directTool" value="3A. 是：先执行预判工具&#xa;executeTool(..., step=0)&#xa;例：calculator/weather/search" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#7c2d12;fontSize=13;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="175" y="650" width="300" height="100" as="geometry" />
        </mxCell>

        <mxCell id="appendPreTool" value="4A. 工具结果写回 messages&#xa;messages.add(assistant: @skill/@mcp...)&#xa;messages.add(tool: observation)&#xa;然后再进入模型循环" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#7c2d12;fontSize=13;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="175" y="815" width="300" height="120" as="geometry" />
        </mxCell>

        <mxCell id="loopStart" value="5. 进入第 step 轮模型循环&#xa;for step = 0; step &lt; MAX_AGENT_STEPS; step++&#xa;当前代码 MAX_AGENT_STEPS = 3" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1e3a8a;fontSize=13;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="560" y="850" width="380" height="105" as="geometry" />
        </mxCell>

        <mxCell id="invokeModel" value="6. 调用模型&#xa;invokeModel(command, context, messages, parentSpanId, step+1)&#xa;这里才真正请求模型" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontColor=#5b21b6;fontSize=13;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="560" y="1015" width="380" height="105" as="geometry" />
        </mxCell>

        <mxCell id="parseDecision" value="7. 模型返回的是工具指令吗？&#xa;parseToolCall(result.assistantMessage())&#xa;只识别 @skill: 或 @mcp:" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontColor=#92400e;fontSize=12;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="590" y="1180" width="320" height="155" as="geometry" />
        </mxCell>

        <mxCell id="finish" value="8A. 否：模型已经正常回答&#xa;return ModelInvokeResult&#xa;runModelLoop 结束" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#166534;fontSize=13;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1030" y="1215" width="300" height="95" as="geometry" />
        </mxCell>

        <mxCell id="modelTool" value="8B. 是：执行模型要求的工具&#xa;executeTool(..., step+1)&#xa;工具名和参数来自 @skill/@mcp 后面的 JSON" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#7c2d12;fontSize=13;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="170" y="1205" width="330" height="105" as="geometry" />
        </mxCell>

        <mxCell id="appendModelTool" value="9B. 把本轮工具结果追加到 messages&#xa;messages.add(assistant: 原始 @skill/@mcp 指令)&#xa;messages.add(tool: 工具输出)&#xa;然后进入下一轮 step" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#7c2d12;fontSize=13;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="170" y="1390" width="330" height="130" as="geometry" />
        </mxCell>

        <mxCell id="maxSteps" value="10. 超过 MAX_AGENT_STEPS 仍未正常回答&#xa;抛出 AGENT_MAX_STEPS_EXCEEDED&#xa;防止工具-模型无限循环" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#7f1d1d;fontSize=13;align=center;verticalAlign=middle;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="585" y="1420" width="330" height="105" as="geometry" />
        </mxCell>

        <mxCell id="example" value="例子：问“重庆明天天气适合团建吗？”&#xa;1. 规则发现 weather 可用且文本包含“天气” -> 先执行 weather。&#xa;2. 天气结果写回 messages。&#xa;3. 再调用模型，模型基于天气结果回答。&#xa;4. 如果模型没有再返回 @skill/@mcp，循环结束。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontColor=#334155;fontSize=13;align=left;verticalAlign=middle;spacing=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="980" y="1410" width="390" height="135" as="geometry" />
        </mxCell>

        <mxCell id="e1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="start" target="copyMessages"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="copyMessages" target="directDecision"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3yes" value="是，不调用模型" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontColor=#7c2d12;" edge="1" parent="1" source="directDecision" target="directTool"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="directTool" target="appendPreTool"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e5" value="带工具结果进入循环" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontColor=#7c2d12;" edge="1" parent="1" source="appendPreTool" target="loopStart"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3no" value="否，交给模型" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontColor=#1e3a8a;" edge="1" parent="1" source="directDecision" target="loopStart"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9673a6;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="loopStart" target="invokeModel"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" value="assistantMessage" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9673a6;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontColor=#5b21b6;" edge="1" parent="1" source="invokeModel" target="parseDecision"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8finish" value="否" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontColor=#166534;" edge="1" parent="1" source="parseDecision" target="finish"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e8tool" value="是" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontColor=#7c2d12;" edge="1" parent="1" source="parseDecision" target="modelTool"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e9" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;" edge="1" parent="1" source="modelTool" target="appendModelTool"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="eLoop" value="下一轮 step：带新工具结果再问模型" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;strokeColor=#d79b00;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontColor=#7c2d12;" edge="1" parent="1" source="appendModelTool" target="loopStart">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="335" y="1585" />
              <mxPoint x="80" y="1585" />
              <mxPoint x="80" y="900" />
              <mxPoint x="545" y="900" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="eMax" value="for 循环耗尽" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;strokeColor=#b85450;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontColor=#7f1d1d;" edge="1" parent="1" source="loopStart" target="maxSteps"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="730" y="975" /><mxPoint x="730" y="1400" /></Array></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
