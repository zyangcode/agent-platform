        <mxCell id="laneMain" value="一、主编排链路：Gateway -> Core Agent Runtime" style="swimlane;startSize=34;rounded=1;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#60a5fa;fontColor=#1e40af;fontStyle=1;fontSize=15;container=1;recursiveResize=0;" vertex="1" parent="1">
