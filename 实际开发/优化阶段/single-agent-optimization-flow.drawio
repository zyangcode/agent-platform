        <mxCell id="43" value="内部请求，保持 SSE" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="4" source="6" target="7">
          <mxGeometry relative="1" as="geometry" />
