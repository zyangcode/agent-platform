        <mxCell id="48" value="用户问题 -> query vector" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="11" source="14" target="15">
          <mxGeometry relative="1" as="geometry" />
