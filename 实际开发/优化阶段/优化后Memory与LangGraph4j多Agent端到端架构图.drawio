          <mxGeometry x="50" y="995" width="2000" height="130" as="geometry" />
        </mxCell>
        <mxCell id="g1" value="Memory 写入准入&#xa;敏感数据阻断/脱敏&#xa;用户显式 forget 优先" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="guard">
          <mxGeometry x="35" y="52" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="g2" value="冲突记忆处理&#xa;preference/fact supersede&#xa;pinned 不自动覆盖" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="guard">
          <mxGeometry x="360" y="52" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="g3" value="派生索引一致性&#xa;PENDING / INDEXED / FAILED&#xa;reindex / backfill" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="guard">
          <mxGeometry x="685" y="52" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="g4" value="多 Agent 记忆边界&#xa;Planner/Executor/Reviewer 不写长期记忆&#xa;Reflect/Finalize 统一写入" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="guard">
