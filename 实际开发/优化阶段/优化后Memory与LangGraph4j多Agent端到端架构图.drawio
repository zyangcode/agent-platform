          <mxGeometry x="20" y="535" width="130" height="80" as="geometry" />
        </mxCell>

        <mxCell id="data" value="六、底层事实源与派生索引" style="swimlane;startSize=34;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=13;" vertex="1" parent="1">
