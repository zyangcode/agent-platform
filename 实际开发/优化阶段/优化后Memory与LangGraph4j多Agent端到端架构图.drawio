        </mxCell>
        <mxCell id="pg" value="PostgreSQL 事实源&#xa;memories / knowledge_documents / knowledge_chunks&#xa;conversation_messages / trace / token records" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;fontStyle=1;" vertex="1" parent="data">
