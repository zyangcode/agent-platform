          <mxGeometry x="1385" y="52" width="270" height="60" as="geometry" />
        </mxCell>
        <mxCell id="g6" value="高级检索默认关闭&#xa;HyDE / MQE / Neo4j&#xa;评测通过后按 Profile 开启" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="guard">
          <mxGeometry x="1700" y="52" width="260" height="60" as="geometry" />
