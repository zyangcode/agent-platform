        <mxCell id="trace" value="Trace 完整闭环&#xa;graph / node / task / tool&#xa;memory / rag / context" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="lane5">
          <mxGeometry x="20" y="380" width="130" height="105" as="geometry" />
