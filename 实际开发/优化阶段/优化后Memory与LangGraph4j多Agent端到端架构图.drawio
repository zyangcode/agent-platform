        </mxCell>
        <mxCell id="qdrant" value="Qdrant 派生向量索引&#xa;collection=memory&#xa;collection=rag&#xa;可重建，不是事实源" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="data">
          <mxGeometry x="500" y="55" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="tsvector" value="PG tsvector 派生倒排索引&#xa;memories.search_vector&#xa;knowledge_chunks.search_vector" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="data">
          <mxGeometry x="870" y="55" width="310" height="80" as="geometry" />
        </mxCell>
        <mxCell id="neo4j" value="Neo4j 派生图谱索引（可选）&#xa;用户事实/偏好图谱&#xa;文档实体关系图谱&#xa;默认关闭" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="data">
