<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="单Agent核心流程简版">
    <mxGraphModel dx="1800" dy="1400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1380" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="单 Agent 核心流程图（按当前代码补全，runModelLoop 保持简版）" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=22;fontStyle=1;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="210" y="20" width="1380" height="42" as="geometry" />
        </mxCell>

        <mxCell id="top" value="一、run() 外层：进入 runModelLoop 前后实际做了什么" style="swimlane;startSize=30;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontStyle=1;fontSize=13;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="60" y="85" width="1680" height="155" as="geometry" />
        </mxCell>
        <mxCell id="r1" value="run(command)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=12;fontStyle=1;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="100" y="140" width="130" height="46" as="geometry" />
        </mxCell>
        <mxCell id="r2" value="validate + start span" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;fontSize=11;fontColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="270" y="140" width="145" height="46" as="geometry" />
        </mxCell>
        <mxCell id="r3" value="ensureConversation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=11;fontColor=#0c4a6e;" vertex="1" parent="1">
          <mxGeometry x="455" y="140" width="145" height="46" as="geometry" />
        </mxCell>
        <mxCell id="r4" value="buildContext" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=11;fontStyle=1;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="640" y="140" width="130" height="46" as="geometry" />
        </mxCell>
        <mxCell id="r5" value="TEAM ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=11;fontStyle=1;fontColor=#78350f;" vertex="1" parent="1">
          <mxGeometry x="820" y="125" width="90" height="76" as="geometry" />
        </mxCell>
        <mxCell id="r6" value="save user" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=11;fontColor=#0c4a6e;" vertex="1" parent="1">
          <mxGeometry x="970" y="140" width="110" height="46" as="geometry" />
        </mxCell>
        <mxCell id="r7" value="runModelLoop" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=12;fontStyle=1;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="1120" y="140" width="130" height="46" as="geometry" />
        </mxCell>
        <mxCell id="r8" value="buildFinalAnswer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=11;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="1290" y="140" width="140" height="46" as="geometry" />
        </mxCell>
        <mxCell id="r9" value="save assistant&#xa;+ saveMemory" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=11;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="1470" y="132" width="150" height="62" as="geometry" />
        </mxCell>
        <mxCell id="team_side" value="TEAM 分支：save user -> teamRuntimeService.run -> save assistant -> saveMemory -> return" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontSize=10;fontColor=#7c2d12;" vertex="1" parent="1">
          <mxGeometry x="945" y="205" width="420" height="30" as="geometry" />
        </mxCell>

        <mxCell id="main" value="二、runModelLoop() 简版主流程" style="swimlane;startSize=30;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontStyle=1;fontSize=13;fontColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="330" y="280" width="880" height="1050" as="geometry" />
        </mxCell>
        <mxCell id="A" value="runModelLoop() 入口" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="630" y="330" width="250" height="50" as="geometry" />
        </mxCell>
        <mxCell id="B" value="复制 messages ← context.apiMessages&#xa;解析 availableTools" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="560" y="415" width="390" height="58" as="geometry" />
        </mxCell>
        <mxCell id="C" value="pendingToolCall != null ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="625" y="505" width="260" height="82" as="geometry" />
        </mxCell>
        <mxCell id="C_ok" value="已确认 / 没有 pending&#xa;进入循环" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="960" y="515" width="180" height="58" as="geometry" />
        </mxCell>
        <mxCell id="C_stop" value="未确认 → 注入确认提示&#xa;fallbackDirectAnswer → return" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="370" y="520" width="220" height="58" as="geometry" />
        </mxCell>
        <mxCell id="D" value="ReAct 循环：step &lt; 6&#xa;最多 6 轮模型调用 / 8 次工具调用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="630" width="390" height="58" as="geometry" />
        </mxCell>
        <mxCell id="E" value="compactMessages()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="600" y="725" width="310" height="48" as="geometry" />
        </mxCell>
        <mxCell id="F" value="invokeModel() 调用 LLM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="585" y="815" width="340" height="48" as="geometry" />
        </mxCell>
        <mxCell id="G" value="模型调了工具？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="905" width="270" height="90" as="geometry" />
        </mxCell>
        <mxCell id="G_no" value="没调工具&#xa;尝试天气 repair&#xa;仍无工具 → 返回最终答案" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="960" y="920" width="210" height="70" as="geometry" />
        </mxCell>
        <mxCell id="G_err" value="解析异常 / 循环耗尽 / 工具次数超限&#xa;→ fallbackDirectAnswer → return" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="920" width="245" height="70" as="geometry" />
        </mxCell>
        <mxCell id="H" value="工具可用且参数有效？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="625" y="1030" width="260" height="88" as="geometry" />
        </mxCell>
        <mxCell id="H_no" value="否 → 注入 tool unavailable / invalid&#xa;fallbackDirectAnswer → return" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="360" y="1042" width="245" height="62" as="geometry" />
        </mxCell>
        <mxCell id="I" value="executeToolBatch() 执行工具&#xa;结果写入 messages" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="560" y="1160" width="390" height="58" as="geometry" />
        </mxCell>
        <mxCell id="J" value="recordToolEvents()&#xa;记录 action / observation / tool_confirm_required" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="560" y="1250" width="390" height="58" as="geometry" />
        </mxCell>
        <mxCell id="continue_note" value="continue：工具成功后回到下一轮模型，让模型基于工具结果判断是否还要继续调用工具。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=2;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="960" y="1162" width="190" height="86" as="geometry" />
        </mxCell>

        <mxCell id="right" value="三、右侧补全：只放代码事实，不挤进主流程" style="swimlane;startSize=30;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontStyle=1;fontSize=13;fontColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="1240" y="280" width="500" height="790" as="geometry" />
