        <mxCell id="S1" value="ContextBuilder 当前组装：&#xa;Profile / Skill / MCP Tool / Memory / Experience / RAG / History / Token budget" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=11;fontStyle=1;fontColor=#14532d;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1270" y="345" width="440" height="90" as="geometry" />
        </mxCell>
        <mxCell id="S2" value="ModelInvoke 当前事实：&#xa;按 modelConfigId 找配置和 provider；返回 assistantMessage / usage / toolCalls；有 stream 时做流式兜底。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=11;fontStyle=1;fontColor=#1e3a8a;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1270" y="470" width="440" height="92" as="geometry" />
        </mxCell>
        <mxCell id="S3" value="工具执行当前事实：&#xa;ToolExecutionPlanner 只并发 readOnly + LOW + resourceKeys 无冲突的工具；最多 4 个。Dispatcher 分流到 SkillExecutor / McpToolExecutor。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;fontColor=#4c1d95;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1270" y="595" width="440" height="108" as="geometry" />
        </mxCell>
        <mxCell id="S4" value="Trace / Token / Hook：&#xa;agent_runtime.run、context.build、model.invoke、tool.validate、tool.plan、tool.execute、final.answer.build、memory.write 都会尽量记 Span；Token usage 在 model.invoke 有 usage 且 traceId 存在时记录。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;fontSize=10;fontStyle=1;fontColor=#334155;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1270" y="735" width="440" height="128" as="geometry" />
        </mxCell>
        <mxCell id="S5" value="Memory 写入：&#xa;只有 profile.memoryStrategy.mode = READ_WRITE 才写。写 SUMMARY，并用 PreferenceExtractor 从用户输入提取偏好。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=11;fontStyle=1;fontColor=#14532d;align=left;spacing=8;" vertex="1" parent="1">
          <mxGeometry x="1270" y="895" width="440" height="88" as="geometry" />
        </mxCell>
        <mxCell id="S6" value="本图没有画的东西：LangGraph、Planner、Reviewer、图状态机、多 Agent 角色拆分。当前单 Agent 代码没有这些主链路。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontSize=11;fontStyle=1;fontColor=#7c2d12;align=left;spacing=8;" vertex="1" parent="1">
