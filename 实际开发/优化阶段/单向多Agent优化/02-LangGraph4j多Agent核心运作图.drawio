<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="01-总体架构与数据流">
    <mxGraphModel dx="1900" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1120" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="LangGraph4j 多 Agent 协作核心运作图（TEAM 外部不变，内部替换旧 Team Runtime）" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="260" y="20" width="1380" height="40" as="geometry" />
        </mxCell>

        <mxCell id="entry" value="一、入口兼容层" style="swimlane;startSize=32;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="50" y="90" width="370" height="420" as="geometry" />
        </mxCell>
        <mxCell id="e_profile" value="Profile.executionMode = TEAM&#xa;前端、Gateway、接口参数不新增模式" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="entry">
          <mxGeometry x="35" y="55" width="300" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e_runtime" value="DefaultAgentRuntimeService&#xa;仍然通过 TeamRuntimeService 调用团队运行时" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="entry">
          <mxGeometry x="35" y="155" width="300" height="75" as="geometry" />
        </mxCell>
        <mxCell id="e_api" value="TeamRuntimeService 接口保留&#xa;保证 SSE、Trace、前端展示兼容" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="entry">
          <mxGeometry x="35" y="260" width="300" height="70" as="geometry" />
        </mxCell>
        <mxCell id="e_new" value="LangGraphTeamRuntimeService&#xa;唯一 TeamRuntimeService Bean&#xa;旧 DefaultTeamRuntimeService 下线/删除" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="entry">
          <mxGeometry x="35" y="355" width="300" height="80" as="geometry" />
        </mxCell>

        <mxCell id="main" value="二、LangGraph4j 主图：负责宏观状态机" style="swimlane;startSize=32;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="480" y="90" width="940" height="590" as="geometry" />
        </mxCell>
        <mxCell id="m_context" value="build_team_context&#xa;构建团队上下文快照&#xa;读取 Profile / Skill / MCP / Memory / RAG / limits" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="main">
          <mxGeometry x="40" y="60" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m_plan" value="plan&#xa;Planner 只拆任务，不调工具&#xa;输出 taskId / dependsOn / taskType / expectedOutput" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="main">
          <mxGeometry x="350" y="60" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="m_validate" value="validate_plan&#xa;校验 JSON Schema、任务数、DAG 无环、工具权限" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="main">
          <mxGeometry x="680" y="65" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m_schedule" value="schedule&#xa;根据 dependsOn 选出 ready tasks&#xa;限制 maxParallelTasks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="main">
          <mxGeometry x="40" y="230" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m_execute" value="execute_batch&#xa;并发执行 ready tasks&#xa;动态任务并发放在节点内部" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="main">
          <mxGeometry x="350" y="220" width="240" height="95" as="geometry" />
        </mxCell>
        <mxCell id="m_eval" value="evaluate_tasks&#xa;子任务评估者&#xa;检查 expectedOutput，失败原因写回 state" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="main">
          <mxGeometry x="680" y="225" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="m_route" value="route_after_tasks&#xa;失败且有预算 → replan&#xa;还有 ready → schedule&#xa;全部完成 → global_review" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="main">
          <mxGeometry x="370" y="365" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="m_replan" value="replan&#xa;失败/缺信息时重规划&#xa;不重复执行已通过任务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="main">
          <mxGeometry x="40" y="385" width="240" height="90" as="geometry" />
        </mxCell>
        <mxCell id="m_review" value="global_review&#xa;整体任务评估者&#xa;审查完成度、矛盾、风险与缺口" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="main">
          <mxGeometry x="680" y="385" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="m_reflect" value="reflect&#xa;反思者生成 MemoryWriteCandidate&#xa;不直接绕过 MemoryWriteService 写表" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="main">
          <mxGeometry x="205" y="510" width="250" height="80" as="geometry" />
        </mxCell>
        <mxCell id="m_final" value="final_answer&#xa;Orchestrator 汇总最终答案&#xa;降级时带风险说明" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="main">
          <mxGeometry x="520" y="510" width="250" height="80" as="geometry" />
        </mxCell>

        <mxCell id="state" value="三、LangGraphTeamState（可序列化状态快照）&#xa;traceId / tenantId / applicationId / userId / profileId&#xa;plan / taskGraph / readyTaskIds / completedResults / failedResults&#xa;memorySnippets / ragSnippets / reflectionCandidates / limits / counters" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1470" y="110" width="360" height="170" as="geometry" />
        </mxCell>

        <mxCell id="exec" value="四、execute_batch 内部：动态并发 + 子图" style="swimlane;startSize=32;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="50" y="735" width="1320" height="250" as="geometry" />
        </mxCell>
        <mxCell id="x_ready" value="readyTaskIds&#xa;本轮可执行任务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="exec">
          <mxGeometry x="35" y="70" width="150" height="65" as="geometry" />
        </mxCell>
        <mxCell id="x_pool" value="CompletableFuture Pool&#xa;bounded executor&#xa;timeout / cancel / 降级" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="exec">
          <mxGeometry x="240" y="60" width="190" height="85" as="geometry" />
        </mxCell>
        <mxCell id="x_tool" value="TOOL_TASK&#xa;简单工具/MCP/Skill 调用&#xa;只由 Executor 拿工具权限" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="exec">
          <mxGeometry x="500" y="50" width="190" height="90" as="geometry" />
        </mxCell>
        <mxCell id="x_model" value="MODEL_TASK&#xa;单步模型分析/生成&#xa;不调用工具" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="exec">
          <mxGeometry x="735" y="50" width="190" height="90" as="geometry" />
        </mxCell>
        <mxCell id="x_react" value="REACT_TASK&#xa;复杂子任务进入 ReActTaskGraph&#xa;think → tool → observe → finish" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;" vertex="1" parent="exec">
          <mxGeometry x="970" y="50" width="220" height="90" as="geometry" />
        </mxCell>
        <mxCell id="x_merge" value="合并 ExecutionResultDTO&#xa;completedResults / failedResults / lastError 写回 LangGraphTeamState" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="exec">
          <mxGeometry x="485" y="170" width="470" height="55" as="geometry" />
        </mxCell>

        <mxCell id="mem" value="五、Memory / RAG / Experience 接入边界" style="swimlane;startSize=32;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1450" y="340" width="390" height="390" as="geometry" />
        </mxCell>
        <mxCell id="mem_schema" value="Team 专用 Context Schema&#xa;TEAM_PLANNER / TEAM_EXECUTOR&#xa;TEAM_REVIEWER / TEAM_REFLECTION" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="mem">
          <mxGeometry x="35" y="55" width="320" height="75" as="geometry" />
        </mxCell>
        <mxCell id="mem_read" value="读：MemorySlotSource / RagSlotSource&#xa;Planner/Executor/Reviewer 只读快照&#xa;RAG 可 citation，Memory 不做 citation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="mem">
          <mxGeometry x="35" y="155" width="320" height="85" as="geometry" />
        </mxCell>
        <mxCell id="mem_write" value="写：ReflectNode → MemoryWriteCandidate&#xa;FinalizeMemoryWritesNode 统一写入&#xa;准入 / 脱敏 / 去重 / 冲突处理" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;" vertex="1" parent="mem">
          <mxGeometry x="35" y="265" width="320" height="90" as="geometry" />
        </mxCell>

        <mxCell id="obs" value="六、观测与运行护栏" style="swimlane;startSize=32;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="1450" y="765" width="390" height="220" as="geometry" />
        </mxCell>
        <mxCell id="obs_sse" value="SSE 兼容现有 Team 事件&#xa;team_start / team_plan / team_task_* / team_review / team_final" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="obs">
          <mxGeometry x="35" y="50" width="320" height="65" as="geometry" />
        </mxCell>
        <mxCell id="obs_trace" value="Trace Span 分层&#xa;team.graph / team.node / team.task / team.tool / memory.write" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="obs">
          <mxGeometry x="35" y="135" width="320" height="65" as="geometry" />
        </mxCell>

        <mxCell id="key" value="关键口径：LangGraph4j 只负责宏观状态机；动态任务并发在 execute_batch 内；长期记忆只在 Reflect/Finalize 阶段写入；外部 TEAM 模式和 SSE 事件尽量兼容旧前端。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="1030" width="1460" height="55" as="geometry" />
        </mxCell>

