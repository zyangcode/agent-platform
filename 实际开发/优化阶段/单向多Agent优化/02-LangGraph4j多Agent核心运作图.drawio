        <mxCell id="d_valid" value="计划有效？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="flow"><mxGeometry x="810" y="65" width="120" height="90" as="geometry" /></mxCell>
