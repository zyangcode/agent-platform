<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="LangGraph4j多Agent核心运作一页图">
    <mxGraphModel dx="2100" dy="1300" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2100" pageHeight="1300" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title" value="LangGraph4j 多 Agent 核心运作图：主路线、异常回路、执行细节、记忆边界合并版" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=22;fontStyle=1;fontColor=#1f2937;" vertex="1" parent="1">
          <mxGeometry x="270" y="20" width="1540" height="44" as="geometry" />
        </mxCell>

        <mxCell id="legend_box" value="图例：读图时先看粗蓝箭头主路线，再看红色回路和绿色/灰色侧边能力" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontSize=13;fontStyle=1;fontColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="1960" height="88" as="geometry" />
        </mxCell>
        <mxCell id="legend_main_shape" value="处理节点" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=12;fontStyle=1;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="125" y="112" width="110" height="36" as="geometry" />
        </mxCell>
        <mxCell id="legend_decision_shape" value="条件判断" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=11;fontStyle=1;fontColor=#78350f;" vertex="1" parent="1">
          <mxGeometry x="285" y="103" width="100" height="54" as="geometry" />
        </mxCell>
        <mxCell id="legend_state_shape" value="状态快照" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;fontSize=11;fontStyle=1;fontColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="435" y="103" width="105" height="54" as="geometry" />
        </mxCell>
        <mxCell id="legend_main_arrow_label" value="粗蓝箭头：主执行路线" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#1e40af;" vertex="1" parent="1">
          <mxGeometry x="610" y="96" width="180" height="30" as="geometry" />
        </mxCell>
        <mxCell id="legend_retry_arrow_label" value="红色虚线：失败、重试、重规划" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#991b1b;" vertex="1" parent="1">
          <mxGeometry x="850" y="96" width="210" height="30" as="geometry" />
        </mxCell>
        <mxCell id="legend_memory_arrow_label" value="绿色虚线：Memory / RAG 读写边界" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#166534;" vertex="1" parent="1">
          <mxGeometry x="1125" y="96" width="235" height="30" as="geometry" />
        </mxCell>
        <mxCell id="legend_obs_arrow_label" value="灰色虚线：State / SSE / Trace / Token" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#475569;" vertex="1" parent="1">
          <mxGeometry x="1435" y="96" width="260" height="30" as="geometry" />
        </mxCell>
        <mxCell id="legend_parallel_arrow_label" value="紫色：execute_batch 内部并发与子图" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#6b21a8;" vertex="1" parent="1">
          <mxGeometry x="1755" y="96" width="255" height="30" as="geometry" />
        </mxCell>
        <mxCell id="legend_arrow_main" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=4;endArrow=block;endFill=1;" edge="1" parent="1" source="legend_main_shape" target="legend_decision_shape">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="entry_lane" value="1. 入口兼容层：外部 TEAM 模式不变" style="swimlane;startSize=34;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontStyle=1;fontSize=14;fontColor=#7c2d12;" vertex="1" parent="1">
          <mxGeometry x="80" y="210" width="250" height="680" as="geometry" />
        </mxCell>
        <mxCell id="node_profile" value="Profile&#xa;executionMode = TEAM&#xa;前端/Gateway 参数不新增模式" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fed7aa;strokeColor=#ea580c;fontSize=11;fontStyle=1;fontColor=#7c2d12;" vertex="1" parent="1">
          <mxGeometry x="105" y="285" width="200" height="76" as="geometry" />
        </mxCell>
        <mxCell id="node_default_runtime" value="DefaultAgentRuntimeService&#xa;仍通过 TeamRuntimeService 进入团队运行时" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontSize=11;fontColor=#7c2d12;" vertex="1" parent="1">
          <mxGeometry x="105" y="420" width="200" height="78" as="geometry" />
        </mxCell>
        <mxCell id="node_team_api" value="TeamRuntimeService&#xa;接口保留&#xa;兼容 SSE / Trace / 前端展示" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontSize=11;fontColor=#7c2d12;" vertex="1" parent="1">
          <mxGeometry x="105" y="560" width="200" height="82" as="geometry" />
        </mxCell>
        <mxCell id="node_langgraph_service" value="LangGraphTeamRuntimeService&#xa;唯一 TeamRuntimeService Bean&#xa;替换旧 DefaultTeamRuntimeService" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=11;fontStyle=1;fontColor=#7f1d1d;" vertex="1" parent="1">
          <mxGeometry x="105" y="705" width="200" height="86" as="geometry" />
        </mxCell>

        <mxCell id="main_lane" value="2. 主路线：LangGraph4j StateGraph 负责宏观状态机" style="swimlane;startSize=34;whiteSpace=wrap;html=1;fillColor=#eff6ff;strokeColor=#2563eb;fontStyle=1;fontSize=14;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="380" y="210" width="1210" height="680" as="geometry" />
        </mxCell>
        <mxCell id="node_start" value="START" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=13;fontStyle=1;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="420" y="305" width="82" height="48" as="geometry" />
        </mxCell>
        <mxCell id="node_context" value="build_team_context&#xa;构建团队上下文快照&#xa;Profile / Skill / MCP / Memory / RAG / limits" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=11;fontStyle=1;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="545" y="282" width="195" height="92" as="geometry" />
        </mxCell>
        <mxCell id="node_plan" value="plan&#xa;Planner 只拆任务&#xa;输出 task DAG 和 expectedOutput" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=11;fontStyle=1;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="790" y="282" width="170" height="92" as="geometry" />
        </mxCell>
        <mxCell id="node_validate" value="validate_plan&#xa;JSON Schema / DAG 无环&#xa;任务数 / 工具权限 / limits" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=11;fontStyle=1;fontColor=#78350f;" vertex="1" parent="1">
          <mxGeometry x="1005" y="282" width="185" height="92" as="geometry" />
        </mxCell>
        <mxCell id="decision_valid" value="计划有效？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=12;fontStyle=1;fontColor=#78350f;" vertex="1" parent="1">
          <mxGeometry x="1240" y="277" width="130" height="102" as="geometry" />
        </mxCell>
        <mxCell id="node_schedule" value="schedule&#xa;按 dependsOn 选择 ready tasks&#xa;限制 maxParallelTasks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=11;fontStyle=1;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="1420" y="282" width="170" height="92" as="geometry" />
        </mxCell>
        <mxCell id="node_execute" value="execute_batch&#xa;并发执行 ready tasks&#xa;动态并发放在节点内部" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=11;fontStyle=1;fontColor=#4c1d95;" vertex="1" parent="1">
          <mxGeometry x="1420" y="455" width="170" height="90" as="geometry" />
        </mxCell>
        <mxCell id="node_eval" value="evaluate_tasks&#xa;子任务结果验收&#xa;检查 expectedOutput 和失败原因" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=11;fontStyle=1;fontColor=#78350f;" vertex="1" parent="1">
          <mxGeometry x="1185" y="455" width="185" height="90" as="geometry" />
        </mxCell>
        <mxCell id="decision_tasks" value="任务状态？&#xa;失败 / 还有 ready / 全部完成" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=10;fontStyle=1;fontColor=#78350f;" vertex="1" parent="1">
          <mxGeometry x="960" y="438" width="155" height="124" as="geometry" />
        </mxCell>
        <mxCell id="node_replan" value="replan&#xa;失败或缺信息时重规划&#xa;不重复执行已通过任务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=11;fontStyle=1;fontColor=#7f1d1d;" vertex="1" parent="1">
          <mxGeometry x="710" y="455" width="180" height="90" as="geometry" />
        </mxCell>
        <mxCell id="node_review" value="global_review&#xa;整体审查完成度、矛盾、风险与缺口" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=11;fontStyle=1;fontColor=#78350f;" vertex="1" parent="1">
          <mxGeometry x="1005" y="665" width="185" height="86" as="geometry" />
        </mxCell>
        <mxCell id="decision_review" value="审查结论？&#xa;通过 / 重规划 / 可降级回答" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=10;fontStyle=1;fontColor=#78350f;" vertex="1" parent="1">
          <mxGeometry x="1240" y="645" width="145" height="126" as="geometry" />
        </mxCell>
        <mxCell id="node_reflect" value="reflect&#xa;根据完整轨迹生成 MemoryWriteCandidate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=11;fontStyle=1;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="1430" y="665" width="170" height="86" as="geometry" />
        </mxCell>
        <mxCell id="node_mem_finalize" value="finalize_memory_writes&#xa;准入 / 脱敏 / 去重 / 冲突处理&#xa;写入失败不阻塞最终回答" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=11;fontStyle=1;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="1120" y="800" width="210" height="86" as="geometry" />
        </mxCell>
        <mxCell id="node_final" value="final_answer&#xa;Orchestrator 汇总最终答案&#xa;降级时说明风险" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=11;fontStyle=1;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="1400" y="800" width="170" height="86" as="geometry" />
        </mxCell>
        <mxCell id="node_end" value="END" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=13;fontStyle=1;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="1518" y="615" width="72" height="46" as="geometry" />
        </mxCell>

        <mxCell id="side_lane" value="3. 侧边能力：状态、记忆、观测只支撑主路线，不抢主线" style="swimlane;startSize=34;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontStyle=1;fontSize=14;fontColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="1640" y="210" width="400" height="680" as="geometry" />
        </mxCell>
        <mxCell id="node_state" value="LangGraphTeamState&#xa;可序列化状态快照&#xa;traceId / userId / profileId&#xa;plan / taskGraph / results&#xa;limits / counters / lastError" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#64748b;fontSize=11;fontStyle=1;fontColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="1685" y="270" width="310" height="130" as="geometry" />
        </mxCell>
        <mxCell id="node_memory" value="Memory / RAG / Experience&#xa;读：Context Slot 快照&#xa;写：只允许 Reflect -> Finalize&#xa;RAG citation 不等于 Memory citation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=11;fontStyle=1;fontColor=#14532d;" vertex="1" parent="1">
          <mxGeometry x="1685" y="445" width="310" height="118" as="geometry" />
        </mxCell>
        <mxCell id="node_observe" value="SSE / Trace / Token 护栏&#xa;team_start / team_plan / team_task_* / team_review / team_final&#xa;Trace: graph / node / task / tool / memory.write&#xa;limits: maxTasks / maxReplans / timeout" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=10;fontStyle=1;fontColor=#7f1d1d;" vertex="1" parent="1">
          <mxGeometry x="1685" y="610" width="310" height="136" as="geometry" />
        </mxCell>
        <mxCell id="node_roles" value="角色边界&#xa;Planner：只规划，不调工具，不写记忆&#xa;Executor/ReAct：执行任务，允许工具&#xa;Evaluator/Reviewer：只评估，不调工具&#xa;Reflector：生成候选，Finalize 统一写入" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#d97706;fontSize=10;fontStyle=1;fontColor=#78350f;" vertex="1" parent="1">
          <mxGeometry x="1685" y="790" width="310" height="150" as="geometry" />
        </mxCell>

        <mxCell id="exec_lane" value="4. execute_batch 内部细节：这里才做动态并发和 ReAct 子图" style="swimlane;startSize=34;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;fontStyle=1;fontSize=14;fontColor=#4c1d95;" vertex="1" parent="1">
          <mxGeometry x="80" y="940" width="1240" height="230" as="geometry" />
        </mxCell>
        <mxCell id="exec_ready" value="readyTaskIds&#xa;本轮可执行任务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=11;fontStyle=1;fontColor=#4c1d95;" vertex="1" parent="1">
          <mxGeometry x="120" y="1025" width="145" height="62" as="geometry" />
        </mxCell>
        <mxCell id="exec_pool" value="bounded CompletableFuture Pool&#xa;timeout / cancel / 降级&#xa;限制 maxParallelTasks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=11;fontStyle=1;fontColor=#4c1d95;" vertex="1" parent="1">
          <mxGeometry x="330" y="1008" width="190" height="94" as="geometry" />
        </mxCell>
        <mxCell id="exec_tool" value="TOOL_TASK&#xa;MCP / Skill / 外部工具&#xa;只由 Executor 拿工具权限" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffedd5;strokeColor=#ea580c;fontSize=10;fontStyle=1;fontColor=#7c2d12;" vertex="1" parent="1">
          <mxGeometry x="600" y="980" width="180" height="82" as="geometry" />
        </mxCell>
        <mxCell id="exec_model" value="MODEL_TASK&#xa;单步分析或生成&#xa;不调用工具" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#2563eb;fontSize=10;fontStyle=1;fontColor=#1e3a8a;" vertex="1" parent="1">
          <mxGeometry x="820" y="980" width="170" height="82" as="geometry" />
        </mxCell>
        <mxCell id="exec_react" value="REACT_TASK&#xa;子图 think -> tool -> observe -> finish&#xa;有 maxReActSteps 和工具上限" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;fontSize=10;fontStyle=1;fontColor=#7f1d1d;" vertex="1" parent="1">
          <mxGeometry x="1030" y="980" width="240" height="82" as="geometry" />
        </mxCell>
        <mxCell id="exec_merge" value="合并 ExecutionResultDTO&#xa;completedResults / failedResults / lastError 写回 LangGraphTeamState" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ede9fe;strokeColor=#7c3aed;fontSize=11;fontStyle=1;fontColor=#4c1d95;" vertex="1" parent="1">
          <mxGeometry x="620" y="1110" width="490" height="50" as="geometry" />
        </mxCell>

        <mxCell id="guide_lane" value="5. 阅读指南" style="swimlane;startSize=34;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#64748b;fontStyle=1;fontSize=14;fontColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="1380" y="965" width="660" height="205" as="geometry" />
        </mxCell>
        <mxCell id="guide_text" value="① 从左侧入口开始：TEAM 外部模式不变，只把内部 Bean 换成 LangGraphTeamRuntimeService。&#xa;② 沿粗蓝箭头读主路线：context -> plan -> validate -> schedule -> execute -> evaluate -> review -> reflect -> finalize -> final。&#xa;③ 菱形只负责路由判断：计划无效、任务失败、审查不通过都会走红色虚线回路。&#xa;④ 紫色区域是 execute_batch 的内部实现，不是主图的新分支；它把 ready tasks 并发执行后合并结果。&#xa;⑤ 绿色虚线表示记忆边界：多 Agent 可读 Memory/RAG，但长期记忆只能由 Reflect/Finalize 统一写。&#xa;⑥ 灰色虚线表示运行支撑：State、SSE、Trace、Token 贯穿流程，但不改变业务主路线。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cbd5e1;fontSize=12;fontStyle=1;fontColor=#334155;align=left;spacing=10;" vertex="1" parent="1">
          <mxGeometry x="1405" y="1018" width="610" height="142" as="geometry" />
        </mxCell>

        <mxCell id="edge_entry_1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#ea580c;strokeWidth=3;endArrow=block;endFill=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="node_profile" target="node_default_runtime">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge_entry_2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#ea580c;strokeWidth=3;endArrow=block;endFill=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="node_default_runtime" target="node_team_api">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge_entry_3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#dc2626;strokeWidth=3;endArrow=block;endFill=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="node_team_api" target="node_langgraph_service">
          <mxGeometry relative="1" as="geometry" />
