        <mxCell id="edge_entry_to_start" value="invoke graph" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=4;endArrow=block;endFill=1;fontColor=#1e40af;fontSize=11;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="node_langgraph_service" target="node_start">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="350" y="748" />
              <mxPoint x="350" y="329" />
            </Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="edge_main_1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=4;endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="node_start" target="node_context">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge_main_2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=4;endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="node_context" target="node_plan">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge_main_3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=4;endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="node_plan" target="node_validate">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge_main_4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=4;endArrow=block;endFill=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="node_validate" target="decision_valid">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge_main_5" value="是" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#2563eb;strokeWidth=4;endArrow=block;endFill=1;fontColor=#1e40af;fontSize=11;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="decision_valid" target="node_schedule">
