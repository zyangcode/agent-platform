        <mxCell id="n_replan" value="replan&#xa;失败/缺信息时重规划" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="flow"><mxGeometry x="450" y="240" width="170" height="75" as="geometry" /></mxCell>
        <mxCell id="n_review" value="global_review&#xa;整体审查" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="flow"><mxGeometry x="980" y="240" width="160" height="75" as="geometry" /></mxCell>
        <mxCell id="d_review" value="审查结论？" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="flow"><mxGeometry x="1200" y="230" width="130" height="100" as="geometry" /></mxCell>
        <mxCell id="n_reflect" value="reflect&#xa;生成经验候选" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="flow"><mxGeometry x="1390" y="240" width="150" height="75" as="geometry" /></mxCell>
        <mxCell id="n_memwrite" value="finalize_memory_writes&#xa;统一准入后写长期记忆" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="flow"><mxGeometry x="1185" y="365" width="190" height="75" as="geometry" /></mxCell>
        <mxCell id="n_final" value="final_answer&#xa;最终答复" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="flow"><mxGeometry x="1435" y="365" width="140" height="75" as="geometry" /></mxCell>
