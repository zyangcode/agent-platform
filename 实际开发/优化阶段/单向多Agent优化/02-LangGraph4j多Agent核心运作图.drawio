        <mxCell id="n_execute" value="execute_batch&#xa;并发执行 ready tasks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;fontStyle=1;" vertex="1" parent="flow"><mxGeometry x="1190" y="70" width="160" height="75" as="geometry" /></mxCell>
        <mxCell id="n_eval" value="evaluate_tasks&#xa;子任务结果验收" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="flow"><mxGeometry x="1405" y="70" width="170" height="75" as="geometry" /></mxCell>
