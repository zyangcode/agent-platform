          <mxGeometry x="80" y="210" width="260" height="590" as="geometry"/>
        </mxCell>
        <mxCell id="profile" value="Profile&#xa;executionMode = TEAM&#xa;用户/前端/Gateway 不新增运行模式" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=12;fontStyle=1;fontColor=#075985;" vertex="1" parent="1">
