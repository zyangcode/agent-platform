        </mxCell>
        <mxCell id="scope" value="定位：保留 DefaultTeamRuntimeService 作为 TeamRuntimeService 默认入口，只把内部手写编排替换成 LangGraph4j StateGraph。第一版不做任务并发、ReAct 子图、Reflect 记忆写入、Checkpoint、Human-in-the-loop。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontSize=14;fontStyle=1;fontColor=#7c2d12;spacing=10;" vertex="1" parent="1">
