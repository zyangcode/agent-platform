        <mxCell id="sq4" value="Neo4j: Entity节点+关系边  (图谱)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;" vertex="1" parent="storage-q">
          <mxGeometry x="1120" y="28" width="340" height="30" as="geometry" />
