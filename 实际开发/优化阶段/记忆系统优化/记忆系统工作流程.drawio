        <mxCell id="pgfetch" value="PostgreSQL 回表取完整原文  (knowledge_chunks / memories)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontStyle=1;" vertex="1" parent="1">
