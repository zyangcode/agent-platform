        <mxCell id="eg2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d79b00;" edge="1" parent="1" source="g2" target="g3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="rrf" value="RRF 融合排序: score = 1/(60+rank)  三路排名统一分数降序排列" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="420" width="520" height="45" as="geometry" />
        </mxCell>
        <mxCell id="er1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;exitX=0.5;exitY=1;entryX=0.2;entryY=0;" edge="1" parent="1" source="v3" target="rrf">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="140" y="400" /><mxPoint x="484" y="400" /></Array></mxGeometry>
        </mxCell>
        <mxCell id="er2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="k3" target="rrf">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="er3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d79b00;exitX=0.5;exitY=1;entryX=0.8;entryY=0;" edge="1" parent="1" source="g3" target="rrf">
          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="1140" y="400" /><mxPoint x="796" y="400" /></Array></mxGeometry>
        </mxCell>

        <mxCell id="decay" value="记忆衰减排序: S = a*exp(-L*t) + b*cos(v,v_q) + c*importance + d*accessBoost" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="485" width="520" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ed1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9673a6;" edge="1" parent="1" source="rrf" target="decay">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="dedup" value="语义去重: 相似度 &gt;= 0.85 合并为一条（保留importance最高的）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="545" width="520" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ed2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#9673a6;" edge="1" parent="1" source="decay" target="dedup">
