        <mxCell id="sr3" value="Neo4j (知识图谱)&#xa;实体+关系 (可重建)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=9;" vertex="1" parent="storage-r">
          <mxGeometry x="790" y="28" width="260" height="40" as="geometry" />
