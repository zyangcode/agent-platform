        </mxCell>

        <mxCell id="slot1" value="注入 TASK_MEMORY Slot  (记忆)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="680" width="400" height="40" as="geometry" />
        </mxCell>
        <mxCell id="slot2" value="注入 RAG_RECALL Slot  (知识库)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
