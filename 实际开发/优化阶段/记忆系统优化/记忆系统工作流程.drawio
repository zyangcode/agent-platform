        <mxCell id="legend" value="统一口径：PostgreSQL 是事实源；Qdrant / PG tsvector / Neo4j 都是派生索引。Memory 只做个性化上下文，不做 citation；RAG 才做外部知识引用。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="1060" width="1300" height="50" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
