        </mxCell>

        <mxCell id="index-label" value="三路索引写入（并行）" style="text;html=1;strokeColor=none;fillColor=#f5f5f5;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="505" width="180" height="20" as="geometry" />
        </mxCell>

        <mxCell id="idx1" value="向量索引: Embedding -&gt; upsert -&gt; Qdrant (collection=memory)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="540" width="360" height="45" as="geometry" />
        </mxCell>
        <mxCell id="idx2" value="知识图谱: LLM提取实体关系 -&gt; Neo4j CREATE节点和关系边" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="540" width="360" height="45" as="geometry" />
        </mxCell>
        <mxCell id="idx3" value="倒排索引(自动): PG tsvector GENERATED ALWAYS AS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1060" y="540" width="360" height="45" as="geometry" />
