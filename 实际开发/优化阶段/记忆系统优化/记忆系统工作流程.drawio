        <mxCell id="reix2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d79b00;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="r-chunks" target="r-idx2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="reix3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;exitX=0.85;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="r-chunks" target="r-idx3">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="974" y="340" />
              <mxPoint x="1250" y="340" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="r-done" value="索引完成 -&gt; 文档状态 INDEXED -&gt; 下次对话通过图1 RAG_RECALL Slot 召回" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="480" width="800" height="40" as="geometry" />
        </mxCell>
        <mxCell id="re4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;" edge="1" parent="1" source="r-idx2" target="r-done">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r-fallback-box" value="容错降级" style="swimlane;startSize=22;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="560" width="1380" height="65" as="geometry" />
        </mxCell>
        <mxCell id="r-fallback-v" value="Embedding/Qdrant失败: 向量跳过 PG keyword补位" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="r-fallback-box">
          <mxGeometry x="60" y="28" width="360" height="30" as="geometry" />
        </mxCell>
        <mxCell id="r-fallback-g" value="LLM/Neo4j失败: 图谱跳过 向量+倒排仍可用" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="r-fallback-box">
          <mxGeometry x="500" y="28" width="360" height="30" as="geometry" />
        </mxCell>
        <mxCell id="r-fallback-k" value="PG tsvector自动列无需容错: 与chunk在同一事务内" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;" vertex="1" parent="r-fallback-box">
          <mxGeometry x="940" y="28" width="360" height="30" as="geometry" />
        </mxCell>
        <mxCell id="storage-r" value="最终存储位置汇总" style="swimlane;startSize=22;fillColor=#666666;strokeColor=#333333;fontSize=10;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="60" y="660" width="1380" height="75" as="geometry" />
