        <mxCell id="output" value="拼入 System Prompt -&gt; apiMessages -&gt; 发往 LLM" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
