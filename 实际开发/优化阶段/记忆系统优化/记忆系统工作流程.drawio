          <mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="880" y="760" /><mxPoint x="880" y="773" /></Array></mxGeometry>
        </mxCell>

        <mxCell id="storage-q" value="数据来源" style="swimlane;startSize=22;fillColor=#666666;strokeColor=#333333;fontSize=10;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="30" y="830" width="1540" height="65" as="geometry" />
