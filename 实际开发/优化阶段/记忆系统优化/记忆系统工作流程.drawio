<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="21.6.0">
  <diagram name="查询检索流程" id="query-flow">
    <mxGraphModel grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="title1" value="记忆系统 - 查询检索流程（上下文组建时的召回）" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="10" width="700" height="35" as="geometry" />
        </mxCell>

        <mxCell id="user-input" value="用户输入（当前对话消息）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="650" y="55" width="300" height="40" as="geometry" />
        </mxCell>

        <mxCell id="qe-group" value="查询增强（可选，模糊查询时触发）" style="swimlane;startSize=22;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="120" width="1100" height="65" as="geometry" />
        </mxCell>
        <mxCell id="hyde" value="HyDE: LLM生成假设答案 -&gt; 用答案向量检索" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="qe-group">
          <mxGeometry x="80" y="28" width="430" height="30" as="geometry" />
        </mxCell>
        <mxCell id="mqe" value="MQE: 拆分子查询 -&gt; 并行搜索 -&gt; 合并去重" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="qe-group">
          <mxGeometry x="590" y="28" width="430" height="30" as="geometry" />
        </mxCell>

        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#9673a6;dashed=1;" edge="1" parent="1" source="user-input" target="qe-group">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="lane-vector" value="路径一：向量语义检索" style="text;html=1;strokeColor=none;fillColor=#dae8fc;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="210" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="lane-keyword" value="路径二：倒排索引检索" style="text;html=1;strokeColor=none;fillColor=#d5e8d4;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="540" y="210" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="lane-graph" value="路径三：知识图谱检索" style="text;html=1;strokeColor=none;fillColor=#ffe6cc;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1040" y="210" width="200" height="25" as="geometry" />
        </mxCell>

        <mxCell id="v1" value="Embedding 查询向量化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="245" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="v2" value="Qdrant ANN (collection=memory/rag)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="295" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="v3" value="候选集 Top-K" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="345" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="ev1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;" edge="1" parent="1" source="v1" target="v2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ev2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;" edge="1" parent="1" source="v2" target="v3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="k1" value="关键词提取 + 中英文分词" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="550" y="245" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="k2" value="PG tsvector GIN 全文检索" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="550" y="295" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="k3" value="ts_rank() BM25 打分 (候选Top-K)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="550" y="345" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="ek1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;" edge="1" parent="1" source="k1" target="k2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ek2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#82b366;" edge="1" parent="1" source="k2" target="k3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="g1" value="LLM 实体提取 (NER)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1050" y="245" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="g2" value="Neo4j Cypher 2跳图游走" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1050" y="295" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="g3" value="关联chunk_id (候选Top-K)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1050" y="345" width="180" height="35" as="geometry" />
        </mxCell>
        <mxCell id="eg1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d79b00;" edge="1" parent="1" source="g1" target="g2">
          <mxGeometry relative="1" as="geometry" />
