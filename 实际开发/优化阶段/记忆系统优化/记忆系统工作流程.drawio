          <mxGeometry x="500" y="55" width="500" height="45" as="geometry" />
        </mxCell>
        <mxCell id="r-save-doc" value="写入 knowledge_documents 表 (PG业务真相: title + content + SHA256 hash去重)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="430" y="130" width="640" height="40" as="geometry" />
        </mxCell>
        <mxCell id="re1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;" edge="1" parent="1" source="r-upload" target="r-save-doc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r-split" value="TextSplitter 文本切分 (chunkTokenBudget + overlapTokens)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="430" y="200" width="640" height="40" as="geometry" />
        </mxCell>
        <mxCell id="re2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;" edge="1" parent="1" source="r-save-doc" target="r-split">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r-chunks" value="批量写入 knowledge_chunks 表 (PG业务真相: content + chunkIndex + tokenCount)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="430" y="270" width="640" height="40" as="geometry" />
        </mxCell>
        <mxCell id="re3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;" edge="1" parent="1" source="r-split" target="r-chunks">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="r-index-label" value="三路索引并行写入" style="text;html=1;strokeColor=none;fillColor=#f5f5f5;align=center;verticalAlign=middle;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="335" width="180" height="20" as="geometry" />
        </mxCell>
        <mxCell id="r-idx1" value="向量索引: Embedding(chunk) -&gt; upsert -&gt; Qdrant (collection=rag)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="370" width="380" height="50" as="geometry" />
        </mxCell>
        <mxCell id="r-idx2" value="知识图谱: LLM提取实体关系 -&gt; Neo4j CREATE节点+关系边" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="560" y="370" width="380" height="50" as="geometry" />
        </mxCell>
        <mxCell id="r-idx3" value="倒排索引(自动): PG tsvector GENERATED ALWAYS AS 自动更新" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1060" y="370" width="380" height="50" as="geometry" />
        </mxCell>
        <mxCell id="reix1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#6c8ebf;exitX=0.15;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="r-chunks" target="r-idx1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
