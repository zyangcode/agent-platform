        <mxCell id="es1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#d6b656;exitX=0.3;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="pgfetch" target="slot1">
