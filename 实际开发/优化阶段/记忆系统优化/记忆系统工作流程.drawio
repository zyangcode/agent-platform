        <mxCell id="pref-title" value="线B：偏好提取" style="text;html=1;strokeColor=none;fillColor=#ffe6cc;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="1130" y="210" width="180" height="25" as="geometry" />
        </mxCell>
        <mxCell id="pb1" value="PreferenceExtractor 规则提取 (关键词匹配)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
