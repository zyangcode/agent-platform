<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="SpringSecurity-JWT认证流程">
    <mxGraphModel dx="1600" dy="1100" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="2" value="登录流程&#xa;POST /api/auth/login" style="swimlane;startSize=30;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="60" y="40" width="690" height="430" as="geometry" />
        </mxCell>
        <mxCell id="3" value="访问业务接口流程&#xa;Authorization: Bearer token" style="swimlane;startSize=30;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="850" y="40" width="690" height="430" as="geometry" />
        </mxCell>

        <mxCell id="10" value="Frontend&#xa;输入用户名密码" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="2">
          <mxGeometry x="30" y="70" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="11" value="AuthController&#xa;/api/auth/login" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="2">
          <mxGeometry x="230" y="70" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="12" value="AuthAppService&#xa;编排登录" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="2">
          <mxGeometry x="430" y="70" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="13" value="IdentityAuthService&#xa;core.identity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="2">
          <mxGeometry x="230" y="190" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="14" value="UserMapper&#xa;users 表" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="2">
          <mxGeometry x="30" y="180" width="150" height="80" as="geometry" />
        </mxCell>
        <mxCell id="15" value="PasswordEncoder&#xa;BCrypt matches" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="2">
          <mxGeometry x="430" y="190" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="16" value="JwtTokenService&#xa;生成 accessToken" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="2">
          <mxGeometry x="230" y="315" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="17" value="返回 LoginResponse&#xa;tokenType = Bearer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="2">
          <mxGeometry x="430" y="315" width="150" height="60" as="geometry" />
        </mxCell>

        <mxCell id="20" value="Frontend&#xa;携带 Bearer Token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="3">
          <mxGeometry x="30" y="70" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="21" value="Spring Security&#xa;Filter Chain" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="3">
          <mxGeometry x="230" y="70" width="150" height="60" as="geometry" />
        </mxCell>
        <mxCell id="22" value="JwtAuthenticationFilter&#xa;解析 Authorization" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="3">
          <mxGeometry x="430" y="70" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="23" value="JwtTokenService&#xa;校验签名与过期时间" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="3">
          <mxGeometry x="230" y="190" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="24" value="CurrentUser&#xa;userId / tenantId / roles" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="3">
          <mxGeometry x="430" y="190" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="25" value="SecurityContextHolder&#xa;保存 Authentication" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="3">
          <mxGeometry x="230" y="315" width="170" height="60" as="geometry" />
        </mxCell>
        <mxCell id="26" value="Controller&#xa;@AuthenticationPrincipal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="3">
          <mxGeometry x="430" y="315" width="170" height="60" as="geometry" />
        </mxCell>

        <mxCell id="30" value="未登录 401&#xa;RestAuthenticationEntryPoint" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="390" y="560" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="31" value="无权限 403&#xa;RestAccessDeniedHandler" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="930" y="560" width="260" height="70" as="geometry" />
        </mxCell>
        <mxCell id="32" value="阶段 1 原则&#xa;Spring Security 守 HTTP 入口&#xa;JWT 表达登录身份&#xa;core.identity 处理用户认证业务&#xa;业务资源权限由 core 应用层兜底" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="470" y="720" width="660" height="110" as="geometry" />
        </mxCell>

        <mxCell id="100" value="登录请求" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="2" source="10" target="11">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="101" value="转应用服务" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="2" source="11" target="12">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="102" value="校验账号密码" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="2" source="12" target="13">
          <mxGeometry relative="1" as="geometry">
