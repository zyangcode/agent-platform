        <!-- ===== 右侧注释区 ===== -->
        <mxCell id="note_box" value="关键概念" style="swimlane;startSize=26;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="880" y="720" width="300" height="170" as="geometry" />
        </mxCell>
        <mxCell id="n1" value="DTO(web.dto): 前端入参/出参&#xa;Command(core.xxx.command): Core入参&#xa;Entity(core.xxx.entity): 数据库表&#xa;Result(core.xxx.dto): Core返回" style="text;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=none;fontSize=9;align=left;" vertex="1" parent="note_box">
          <mxGeometry x="10" y="30" width="280" height="60" as="geometry" />
        </mxCell>
        <mxCell id="n2" value="BaseMapper 自带：insert / selectById&#xa;/ selectList / selectPage / updateById&#xa;/ deleteById / selectCount" style="text;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=none;fontSize=9;align=left;" vertex="1" parent="note_box">
          <mxGeometry x="10" y="90" width="280" height="45" as="geometry" />
        </mxCell>
        <mxCell id="n3" value="LambdaQueryWrapper:&#xa;用 .eq(Entity::getField, value)&#xa;代替 SQL 字符串，安全、IDE 可检查" style="text;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=none;fontSize=9;align=left;" vertex="1" parent="note_box">
          <mxGeometry x="10" y="130" width="280" height="40" as="geometry" />
        </mxCell>

        <mxCell id="note_rule" value="跨包调用规则" style="swimlane;startSize=26;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="880" y="720" width="300" height="80" as="geometry" />
        </mxCell>
        <mxCell id="nr1" value="Controller 只调 core.xxx.api 接口&#xa;禁止 Controller → Mapper（越界）&#xa;@Transactional 只在 Application Service" style="text;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=none;fontSize=9;align=left;fontColor=#b85450;" vertex="1" parent="note_rule">
          <mxGeometry x="10" y="28" width="280" height="45" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
