<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="MyBatis-Plus调用链路-用户注册">
    <mxGraphModel>
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- 泳道1: 浏览器/客户端 -->
        <mxCell id="lane1" value="浏览器 / 客户端" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1160" height="100" as="geometry" />
        </mxCell>
        <mxCell id="req" value="POST /api/auth/register&#xa;{&quot;username&quot;:&quot;zhangsan&quot;,&#xa;&quot;password&quot;:&quot;123456&quot;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="lane1">
          <mxGeometry x="80" y="20" width="220" height="55" as="geometry" />
        </mxCell>
        <mxCell id="resp" value="HTTP 200&#xa;{&quot;success&quot;:true,&#xa;&quot;data&quot;:{&quot;userId&quot;:10001,...}}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="lane1">
          <mxGeometry x="860" y="20" width="230" height="55" as="geometry" />
        </mxCell>

        <!-- 泳道2: Web模块 -->
        <mxCell id="lane2" value="Web 模块（HTTP 入口）— 包: web.auth / web.dto" style="swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="20" y="120" width="1160" height="130" as="geometry" />
        </mxCell>
        <mxCell id="ctrl" value="RegisterController&#xa;接收请求" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="lane2">
          <mxGeometry x="80" y="20" width="170" height="55" as="geometry" />
        </mxCell>
        <mxCell id="valid" value="@Validated 校验&#xa;RegisterRequest DTO" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="lane2">
          <mxGeometry x="290" y="20" width="160" height="55" as="geometry" />
        </mxCell>
        <mxCell id="convert" value="DTO → Command 转换&#xa;RegisterRequest&#xa;→ RegisterCommand" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="lane2">
          <mxGeometry x="490" y="15" width="170" height="65" as="geometry" />
        </mxCell>
        <mxCell id="call_svc" value="调用接口&#xa;AuthService&#xa;.register(command)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="lane2">
          <mxGeometry x="700" y="15" width="160" height="65" as="geometry" />
        </mxCell>

        <!-- 泳道3: Core模块 -->
        <mxCell id="lane3" value="Core 模块（业务逻辑）— 包: core.identity.api / core.identity.application" style="swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="20" y="250" width="1160" height="240" as="geometry" />
        </mxCell>
        <mxCell id="svc_impl" value="AuthServiceImpl.register()&#xa;@Transactional" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="lane3">
          <mxGeometry x="80" y="15" width="200" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s1" value="① selectCount&#xa;检查用户名&#xa;是否已存在" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="lane3">
          <mxGeometry x="60" y="90" width="145" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="② encode&#xa;密码加密&#xa;bcrypt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="lane3">
          <mxGeometry x="230" y="90" width="110" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="③ insert(user)&#xa;保存用户&#xa;→ 自动回填 id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="lane3">
          <mxGeometry x="365" y="90" width="155" height="55" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="④ insert(userRole)&#xa;绑定默认&#xa;USER 角色" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="lane3">
          <mxGeometry x="545" y="90" width="150" height="55" as="geometry" />
        </mxCell>
        <mxCell id="result" value="返回 RegisterResult&#xa;(userId, username)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="lane3">
          <mxGeometry x="720" y="90" width="160" height="55" as="geometry" />
        </mxCell>
        <!-- Core内部调用链虚线 -->
        <mxCell id="e_core1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;dashed=1;" edge="1" parent="lane3" source="svc_impl" target="s1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_core2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="lane3" source="s1" target="s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_core3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="lane3" source="s2" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_core4" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="lane3" source="s3" target="s4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_core5" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="lane3" source="s4" target="result">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 泳道4: MyBatis-Plus -->
        <mxCell id="lane4" value="MyBatis-Plus（数据访问层）— 包: core.identity.mapper" style="swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="20" y="490" width="1160" height="130" as="geometry" />
        </mxCell>
        <mxCell id="mp_frame" value="UserMapper extends BaseMapper&lt;UserEntity&gt; — 你写的代码是空的，BaseMapper 提供所有 CRUD" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="lane4">
          <mxGeometry x="80" y="15" width="810" height="40" as="geometry" />
        </mxCell>
        <mxCell id="sql1" value="SELECT COUNT(*) FROM users&#xa;WHERE tenant_id=? AND username=?" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;fontFamily=Courier New;" vertex="1" parent="lane4">
          <mxGeometry x="60" y="70" width="270" height="35" as="geometry" />
        </mxCell>
        <mxCell id="sql2" value="INSERT INTO users (tenant_id,username,&#xa;password_hash,...) VALUES (?,?,?,...)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;fontFamily=Courier New;" vertex="1" parent="lane4">
          <mxGeometry x="350" y="70" width="280" height="35" as="geometry" />
        </mxCell>
        <mxCell id="sql3" value="INSERT INTO user_roles&#xa;(user_id,role_id) VALUES (?,?)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;fontFamily=Courier New;" vertex="1" parent="lane4">
          <mxGeometry x="650" y="70" width="240" height="35" as="geometry" />
        </mxCell>

        <!-- 泳道5: PostgreSQL -->
        <mxCell id="lane5" value="PostgreSQL（数据库）— agent_platform" style="swimlane;startSize=30;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=13;" vertex="1" parent="1">
          <mxGeometry x="20" y="620" width="1160" height="100" as="geometry" />
        </mxCell>
        <mxCell id="db1" value="users 表" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="lane5">
          <mxGeometry x="100" y="18" width="120" height="55" as="geometry" />
        </mxCell>
        <mxCell id="db2" value="user_roles 表" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="lane5">
          <mxGeometry x="280" y="18" width="120" height="55" as="geometry" />
        </mxCell>
        <mxCell id="db3" value="api_keys 表" style="shape=cylinder3;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;" vertex="1" parent="lane5">
          <mxGeometry x="460" y="25" width="110" height="45" as="geometry" />
        </mxCell>
        <mxCell id="db_note" value="... 等 18 张阶段1表" style="text;whiteSpace=wrap;html=1;fillColor=none;strokeColor=none;fontSize=11;fontColor=#666666;" vertex="1" parent="lane5">
          <mxGeometry x="590" y="20" width="120" height="50" as="geometry" />
        </mxCell>

        <!-- ===== 跨泳道连线 ===== -->
        <!-- 浏览器→Web -->
        <mxCell id="e1" value="HTTP Request" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;" edge="1" parent="1" source="req" target="ctrl">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Web内部连线 -->
        <mxCell id="e_w1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="ctrl" target="valid">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_w2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="valid" target="convert">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_w3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="convert" target="call_svc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Web→Core -->
        <mxCell id="e_wc" value="调用 core.identity.api&#xa;AuthService 接口" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10;fontColor=#d79b00;" edge="1" parent="1" source="call_svc" target="svc_impl">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- Core→MyBatis-Plus -->
        <mxCell id="e_cm1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;dashed=1;" edge="1" parent="1" source="s1" target="sql1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_cm2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;dashed=1;" edge="1" parent="1" source="s3" target="sql2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_cm3" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;dashed=1;" edge="1" parent="1" source="s4" target="sql3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <!-- MyBatis-Plus→PostgreSQL -->
        <mxCell id="e_md1" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;flowAnimation=1;" edge="1" parent="1" source="sql1" target="db1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e_md2" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;flowAnimation=1;" edge="1" parent="1" source="sql2" target="db1">
